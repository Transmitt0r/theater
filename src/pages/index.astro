---
import '../styles/global.css';

const baseUrl = import.meta.env.BASE_URL;

const buildFullscreenLaunchUrl = (targetUrl: string) =>
	`https://www.youtube.com/redirect?q=${encodeURIComponent(targetUrl)}`;

const services = [
	{ name: 'Netflix', targetUrl: 'https://www.netflix.com/browse' },
	{ name: 'Disney+', targetUrl: 'https://www.disneyplus.com/home' },
	{ name: 'Prime Video', targetUrl: 'https://www.primevideo.com/' },
	{ name: 'HBO Max', targetUrl: 'https://www.max.com/' },
	{ name: 'YouTube', targetUrl: 'https://www.youtube.com/' },
	{ name: 'ARD Mediathek', targetUrl: 'https://www.ardmediathek.de/' },
	{ name: 'ZDF Mediathek', targetUrl: 'https://www.zdf.de/' }
].map((service) => ({
	...service,
	launchUrl: buildFullscreenLaunchUrl(service.targetUrl)
}));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#0b0d11" />
		<title>Tesla Theater Launcher</title>
	</head>
	<body>
		<main class="launcher" aria-label="Streaming services launcher">
			<header class="launcher__header">
				<p class="launcher__eyebrow">Media</p>
				<h1 class="launcher__title">Theater</h1>
			</header>

			<section class="tile-grid" aria-label="Streaming services">
				{
					services.map((service) => (
						<a
							class="tile"
							href={service.launchUrl}
							target="_self"
							rel="noopener noreferrer"
							data-target-url={service.targetUrl}
						>
							<span class="tile__name">{service.name}</span>
						</a>
					))
				}
			</section>
		</main>

		<script>
			const buildFullscreenLaunchUrl = (targetUrl) =>
				`https://www.youtube.com/redirect?q=${encodeURIComponent(targetUrl)}`;

			const navigateToFullscreenTarget = (targetUrl) => {
				window.location.href = buildFullscreenLaunchUrl(targetUrl);
			};

			document.querySelectorAll('[data-target-url]').forEach((tile) => {
				tile.addEventListener('click', (event) => {
					event.preventDefault();
					const targetUrl = tile.getAttribute('data-target-url');

					if (!targetUrl) {
						return;
					}

					navigateToFullscreenTarget(targetUrl);
				});
			});
		</script>
	</body>
</html>
